# AIF Scrapper Environment Configuration
# Copy this file to .env and fill in your values

# Database (SQLite by default; switch to PostgreSQL for production)
DATABASE_URL=sqlite:///data/aif_scrapper.db
# DATABASE_URL=postgresql://user:password@localhost:5432/aif_scrapper

# Proxy Configuration (optional - leave empty to disable)
# Comma-separated list of proxy URLs
PROXY_POOL=

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/aif_scrapper.log

# Scraping Configuration
FUZZY_MATCH_THRESHOLD=85
REQUEST_DELAY_MIN=2
REQUEST_DELAY_MAX=5
MAX_RETRIES=3
